{
  "name": "pracht-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' --filter='!@pracht/cli' run build",
    "check": "pnpm build && pnpm typecheck && pnpm test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "playwright install chromium",
    "pracht": "node ./packages/cli/bin/pracht.js",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --fix",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "e2e": "playwright test",
    "dev:example": "cd examples/cloudflare && node ../../packages/cli/bin/pracht.js dev",
    "build:example": "cd examples/cloudflare && node ../../packages/cli/bin/pracht.js build",
    "preview:example": "cd examples/cloudflare && node ../../packages/cli/bin/pracht.js preview"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.21",
    "jsonc-parser": "^3.3.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "preact": "^10.26.9",
    "preact-render-to-string": "^6.5.13",
    "tsdown": "^0.21.7",
    "typescript": "^5.8.3",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.28.1"
}
